{
  "port": 3458,
  "dataDir": "./data",
  "auth": {
    "jwtSecret": "REQUIRED — generate with: openssl rand -hex 32",
    "encryptionKey": "RECOMMENDED — generate with: openssl rand -hex 32"
  },
  "webhook": {
    "url": "",
    "events": ["item.created", "item.resolved", "item.assigned"],
    "secret": ""
  },
  "distribution": {
    "rules": [
      {
        "match": { "event": "item.created", "type": "issue" },
        "channels": ["github-example"]
      }
    ],
    "channels": {
      "github-example": {
        "adapter": "github-issue",
        "token": "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
        "repo": "your-org/your-repo",
        "labels": ["clawmark"]
      }
    }
  }
}
