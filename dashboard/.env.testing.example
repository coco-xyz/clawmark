# Copy to .env.testing and adjust for your test environment
# Build with: npx vite build --mode testing

# Google OAuth Client ID for testing (use a separate OAuth app)
VITE_GOOGLE_CLIENT_ID=YOUR_TESTING_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Test server URL (no trailing slash)
VITE_SERVER_URL=http://localhost:13458

# Dashboard base path for test deployment
VITE_BASE_PATH=/clawmark-test/dashboard/
