# ClawMark — Environment Variables
# Copy to .env and fill in values. All variables are optional if set in config.json.

# Server port (default: 3458)
CLAWMARK_PORT=3458

# Data directory for SQLite database and file uploads (default: ./data)
CLAWMARK_DATA_DIR=./data

# Path to config.json (default: ../config.json relative to server/)
CLAWMARK_CONFIG=../config.json

# JWT signing secret (REQUIRED for production)
# Generate with: openssl rand -hex 32
CLAWMARK_JWT_SECRET=

# Credential encryption key — AES-256-GCM, 32 bytes hex (RECOMMENDED)
# Encrypts third-party credentials at rest. Without it, credentials are stored in plaintext.
# Generate with: openssl rand -hex 32
CLAWMARK_ENCRYPTION_KEY=

# Google OAuth credentials (required for Google login)
CLAWMARK_GOOGLE_CLIENT_ID=
CLAWMARK_GOOGLE_CLIENT_SECRET=

# Global webhook (optional, overrides config.json webhook settings)
CLAWMARK_WEBHOOK_URL=
CLAWMARK_WEBHOOK_SECRET=

# Gemini API key for AI features (optional — AI routing, classification, tag generation)
GEMINI_API_KEY=

# Environment name (default: production)
NODE_ENV=production
